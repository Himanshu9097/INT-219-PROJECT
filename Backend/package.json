{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --env NODE_ENV=development --watch src --ext js --exec \"node --import dotenv/config ./src/server.js\"",
    "build": "esbuild src/server.js --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs --sourcemap",
    "start": "node --import dotenv/config --enable-source-maps ./dist/server.mjs",
    "typecheck": "find src -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.4.7",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
