{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/[...path].mjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/login.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/register.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/me.mjs",
      "use": "@vercel/node"
    }
  ]
}
