{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].mjs"
    }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/[...path].mjs",
      "use": "@vercel/node"
    }
  ]
}
